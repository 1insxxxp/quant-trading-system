{
  "name": "quant-trading-backend",
  "version": "1.0.0",
  "description": "量化交易后端服务 - 实时行情",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:local": "tsx scripts/start-local-dev.ts",
    "dev:local:frontend": "tsx scripts/start-local-dev.ts --frontend",
    "dev:local:tunnel": "tsx scripts/start-local-dev.ts --tunnel-only",
    "build": "tsc",
    "start": "node dist/server.js",
    "migrate:sqlite-to-postgres": "tsx scripts/migrate-sqlite-to-postgres.ts",
    "migrate": "tsx scripts/run-migrations.ts",
    "test": "vitest",
    "test:coverage": "vitest --coverage"
  },
  "dependencies": {
    "@types/pg": "^8.18.0",
    "axios": "^1.6.7",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "https-proxy-agent": "^7.0.6",
    "pg": "^8.20.0",
    "redis": "^4.7.0",
    "ssh2": "^1.15.0",
    "sqlite3": "^5.1.7",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.9",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.20",
    "@types/ws": "^8.5.10",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3",
    "vitest": "^1.3.1"
  }
}
